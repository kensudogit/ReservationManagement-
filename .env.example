# Database
POSTGRES_USER=srm
POSTGRES_PASSWORD=srm_secret
POSTGRES_DB=srm
DATABASE_URL=postgresql+psycopg://srm:srm_secret@db:5432/srm

# Backend
SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CANCEL_HOURS_BEFORE=24
CORS_ORIGINS=http://localhost:3000,http://localhost:3020

# Google Calendar OAuth (optional for local demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/callback
FRONTEND_URL=http://localhost:3020

# Stripe (optional — 未設定時はデモ課金モード)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Email SMTP (optional — 未設定時はコンソール出力 + DB 記録)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@studio-reservation.local
SMTP_USE_TLS=true
TAX_RATE=0.10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
